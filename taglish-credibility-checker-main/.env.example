# ─── Mock mode ────────────────────────────────────────────────────────────────
# Set to "true" to use local mock data (no API key required).
# Set to "false" to enable the Gemini-backed analysis route.
NEXT_PUBLIC_USE_MOCK_API=true

# ─── Gemini API (free tier) ────────────────────────────────────────────────────
# Required when NEXT_PUBLIC_USE_MOCK_API=false.
# Get a free key at https://aistudio.google.com/app/apikey
# This key stays server-side only (no NEXT_PUBLIC_ prefix) — never exposed to the browser.
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Legacy external ML backend (optional, future use) ────────────────────────
# Only used if you wire up your own Python/FastAPI backend later.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
