# ─── Mock mode ────────────────────────────────────────────────────────────────
# Set to "false" to use the real model backend.
# Set to "true" (or leave unset) to use local mock data (no API key required).
NEXT_PUBLIC_USE_MOCK_API=false

# ─── Groq API ─────────────────────────────────────────────────────────────────
# Required for AI-powered explanations and image OCR.
# Get a free key at https://console.groq.com
# This key stays server-side only (no NEXT_PUBLIC_ prefix) — never exposed to the browser.
GROQ_API_KEY=your_groq_api_key_here

# ─── FastAPI model backend ────────────────────────────────────────────────────
# URL of the Python FastAPI backend that runs the XLM-RoBERTa model.
# Start it with: cd fastapi-backend && uvicorn main:app --port 8000
FASTAPI_URL=http://127.0.0.1:8000
